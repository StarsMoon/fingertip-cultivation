{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@game/*": ["src/game/*"],
      "@combat/*": ["src/combat/*"],
      "@data/*": ["src/data/*"],
      "@progression/*": ["src/progression/*"],
      "@ui/*": ["src/ui/*"],
      "@render/*": ["src/render/*"],
      "@audio/*": ["src/audio/*"],
      "@utils/*": ["src/utils/*"]
    },
    "types": ["jest"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
